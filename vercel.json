{
    "version": 2,
    "builds": [
        {
            "src": "server/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "server/client/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/server/index.js"
        },
        {
            "source": "/(.*\\.(?:js|css|json|html|png|jpg|jpeg|gif|svg|ico|ttf|woff|woff2|eot|webp|mp4|webm|wav|mp3|txt|xml))",
            "destination": "/server/client/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/server/client/index.html"
        }
    ]
}